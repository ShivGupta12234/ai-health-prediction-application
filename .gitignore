# ============================================
# HealthMateAI — Root .gitignore
# ============================================

# ── Dependencies ─────────────────────────────
node_modules/
**/node_modules/

# ── Environment Variables (CRITICAL) ─────────
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ── Build Outputs ────────────────────────────
dist/
build/
**/dist/
**/build/
.next/
out/

# ── Logs ─────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ── OS Files ─────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE / Editors ────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── Testing & Coverage ───────────────────────
coverage/
*.lcov
.nyc_output/

# ── Misc ─────────────────────────────────────
.cache/
.parcel-cache/
tmp/
temp/
*.tgz
*.tsbuildinfo

# ── Package Manager Locks (keep one) ─────────
# Uncomment if you want to ignore lock files:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ── Vercel ───────────────────────────────────
.vercel/

# ── Debug ────────────────────────────────────
*.pid
*.seed
*.pid.lock
