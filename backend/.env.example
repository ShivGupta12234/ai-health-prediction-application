# ============================================
# HealthMateAI Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Local: mongodb://localhost:27017/health-ai
# Atlas: mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/health-ai
MONGODB_URI=mongodb://localhost:27017/health-ai

# JWT Secret — use a strong random string (min 32 chars)
# Generate one: openssl rand -hex 32
JWT_SECRET=change_me_to_a_secure_random_string

# Frontend URL — used for CORS origin
FRONTEND_URL=http://localhost:3000

# Hugging Face API Key (optional)
# Get one at: https://huggingface.co/settings/tokens
# If not set, predictions use rule-based engine only
# HUGGINGFACE_API_KEY=hf_your_api_key_here
